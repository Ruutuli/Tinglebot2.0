      "elementSource": "item.element",
      "notes": "Armor; not mixer ingredients."
    },
    "Chest": {
      "ingredientRole": "gear",
      "effectFamilySource": "none",
      "elementSource": "item.element",
      "notes": "Armor; not mixer ingredients."
    },
    "Dairy": {
      "ingredientRole": "optionalFood",
      "effectFamilySource": "none",
      "elementSource": "none",
      "notes": "Cooking."
    },
    "Grain": {
      "ingredientRole": "optionalFood",
      "effectFamilySource": "none",
      "elementSource": "none",
      "notes": "Cooking."
    },
    "Fungi": {
      "ingredientRole": "optionalFood",
      "effectFamilySource": "none",
      "elementSource": "none",
      "notes": "Cooking."
    },
    "Protein": {
      "ingredientRole": "optionalFood",
      "effectFamilySource": "none",
